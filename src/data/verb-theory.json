  "title": "Verbtheorie",
  "titleEn": "Verb Theory",
  "intro": [
    { "de": "Ein Verb beschreibt eine Aktion.", "en": "A verb describes an action." },
    { "de": "die Verbstruktur: der Verbstamm + die Endung", "en": "the verb structure: stem + ending" },
    { "de": "lern + en = lernen (Infinitiv)", "en": "to learn (infinitive)" },
    { "de": "Verbkonjugation hängt von zwei Dingen ab: Person und Anzahl.", "en": "Verb conjugation depends on two things: person and count." },
    { "de": "Person: 1. / 2. / 3.  —  Anzahl: Singular / Plural", "en": "Person: 1st / 2nd / 3rd — Count: singular / plural" },
    { "de": "zwei Arten von Verben: 1. regelmäßige (schwache) Verben, 2. unregelmäßige (starke) Verben", "en": "two kinds of verbs: 1. regular (weak), 2. irregular (strong)" }
  ],
  "regularEndings": [
    { "person": "1. Person", "singular": "ich  -e", "plural": "wir  -en" },
    { "person": "2. Person informell", "singular": "du  -st", "plural": "ihr  -t" },
    { "person": "2. Person formell", "singular": "Sie  -en", "plural": "Sie  -en" },
    { "person": "3. Person m/f/n", "singular": "er/sie/es  -t", "plural": "sie  -en" }
  ],
