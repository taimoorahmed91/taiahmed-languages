  "vowelChanges": [
    { "rule": "e → i", "example": "sprechen → du sprichst, er/sie/es spricht" },
    { "rule": "e → ie", "example": "lesen → du liest, er/sie/es liest" },
    { "rule": "au → äu", "example": "laufen → du läufst, er/sie/es läuft" },
